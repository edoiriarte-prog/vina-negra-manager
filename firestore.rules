rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Esta regla permite leer y escribir a cualquier usuario autenticado
    // (Soluciona el error de "Missing permissions" aunque el usuario no tenga email)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
  }
}