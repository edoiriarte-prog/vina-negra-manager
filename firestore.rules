
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /contacts/{contactId} {
      allow read, write: if isSignedIn();
    }

    match /purchaseOrders/{purchaseOrderId} {
      allow read, write: if isSignedIn();
    }

    match /salesOrders/{salesOrderId} {
      allow read, write: if isSignedIn();
    }

    match /serviceOrders/{serviceOrderId} {
      allow read, write: if isSignedIn();
    }

    match /financialMovements/{movementId} {
      allow read, write: if isSignedIn();
    }
    
    match /inventoryAdjustments/{adjustmentId} {
        allow read, write: if isSignedIn();
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /calibers/{caliberId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
    
    match /productCaliberAssociations/{associationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /units/{unitId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /packagingTypes/{packagingTypeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /warehouses/{warehouseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
    
    match /internalConcepts/{conceptId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
    }
    
    match /costCenters/{centerId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
    }
    
    match /bankAccounts/{accountId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
    }
  }
}
