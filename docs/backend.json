{
  "entities": {
    "Contact": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Contact",
      "type": "object",
      "description": "Represents a client or supplier contact.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the contact."
        },
        "rut": {
          "type": "string",
          "description": "Tax identifier for the contact (RUT)."
        },
        "address": {
          "type": "string",
          "description": "Physical address of the contact."
        },
        "commune": {
          "type": "string",
          "description": "Commune or locality of the contact."
        },
        "email": {
          "type": "string",
          "description": "Email address of the contact.",
          "format": "email"
        },
        "contactPerson": {
          "type": "string",
          "description": "Name of the contact person."
        },
        "isClient": {
          "type": "boolean",
          "description": "Indicates if the contact is a client."
        },
        "isSupplier": {
          "type": "boolean",
          "description": "Indicates if the contact is a supplier."
        }
      },
      "required": [
        "id",
        "rut",
        "address",
        "commune",
        "email",
        "contactPerson",
        "isClient",
        "isSupplier"
      ]
    },
