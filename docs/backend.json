        },
        "orderDate": {
          "type": "string",
          "description": "Date when the purchase order was created.",
          "format": "date-time"
        },
        "items": {
          "type": "array",
          "description": "List of items in the purchase order.",
          "items": {
            "type": "string"
          }
        },
        "totalAmount": {
          "type": "number",
          "description": "The total amount of the purchase order."
        }
      },
      "required": [
        "id",
        "supplierId",
        "orderDate",
        "items",
        "totalAmount"
      ]
    },
